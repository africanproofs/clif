.env
# per-network deployment env files (.env.flare/.env.songbird/.env.coston2)
# carry operator-injected fwd caller tokens — never committed (Core #12).
.env.*
!.env.example
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.venv/
# fsp-rewards local cache (mirrors the upstream `rewards-data/` convention)
rewards-data/
# clif auto runtime status (no secrets — status only)
.clif-state/
