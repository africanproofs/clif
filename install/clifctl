#!/bin/sh
# clifctl — lifecycle + one-shot control for the clif deployment.
#
# clif is the FTSO reward AUTOMATION (the epoch-anchored sign→claim daemon) plus the
# manual reward ops (claim / FSP / preflight / chain reads). It is a SEPARATE deployment
# from the fwd signer: its own compose project (`clif`) with its own `egress` bridge,
# joining fwd's `internal: true` callers network as an `external` network to reach
# `fwd:8080`. clif holds ZERO private keys — it signs via fwd and broadcasts itself.
#
#   clifctl up <net>        # start that network's epoch sign→claim daemon (clif-epoch-<net>)
#   clifctl down <net>      # stop + remove it
#   clifctl restart <net>
#   clifctl status [<net>]  # compose state (+ `clif epoch status` when <net> is given)
#   clifctl logs <net>      # follow the daemon's logs
#   clifctl run <net> …     # one-shot manual op: claim / fsp / preflight / chain nonce / rehearse
#   clifctl build           # build the clif image from source
#
# <net> = flare | songbird | coston2  (selects the gitignored .env.<net> created by
# `clifctl import-credentials <net> <bundle>` from the one-shot bundle `fwd onboard`
# publishes to fwd's outbox). The daemon SIGNS, so it stays hard-off
# unless FSP_AUTO_ENABLED=true in that network's .env.<net> (D15).
set -eu

CLIF_DIR="${CLIF_DIR:-/opt/clif}"
# fwd's callers network (external). Must match fwd's compose project name (default `fwd`
# → `fwd_fwd-callers`). fwd must be up first — it creates the network clif attaches to.
export FWD_NETWORK="${FWD_NETWORK:-fwd_fwd-callers}"
# clif's own compose project — independent of fwd's project.
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-clif}"
# fwd's container name — `nonce-sync` writes fwd's nonce (via the clifwd host wrapper) and
# parses clif's chain-read JSON with fwd's bundled python.
FWD_CONTAINER="${FWD_CONTAINER:-fwd}"
cd "$CLIF_DIR" 2>/dev/null || { echo "clifctl: $CLIF_DIR not found (set CLIF_DIR or run clif's install.sh)" >&2; exit 2; }

_net_ok() {
  case "${1:-}" in
    flare|songbird|coston2) ;;
    *) echo "clifctl: network must be flare|songbird|coston2 (got: '${1:-}')" >&2; exit 2 ;;
  esac
}
_chain_id() {  # net -> EVM chain id
  case "$1" in flare) echo 14 ;; songbird) echo 19 ;; coston2) echo 114 ;; *) return 1 ;; esac
}
# Seed fwd's nonce from CHAIN TRUTH for ONE net's tx-sending wallets (claimer + FSP sender;
# fsp-signing has no nonce). fwd is zero-egress, so clif reads the on-chain count and the clifwd
# host wrapper writes fwd's nonce. Idempotent — already-seeded wallets are skipped. Used by both
# `nonce-sync` and (auto) by `import-credentials`. Best-effort — always returns 0.
_ns_one() {  # net
  _n="$1"; _cid=$(_chain_id "$_n") || return 0
  [ -f ".env.$_n" ] || return 0
  printf 'nonce-sync %s (chain %s):\n' "$_n" "$_cid"
  for _wv in FWD_WALLET_NAME FSP_SENDER_WALLET_NAME; do
    _wn=$(sed -n "s/^$_wv=//p" ".env.$_n" 2>/dev/null | head -n1)
    [ -n "$_wn" ] || continue
    if clifwd nonce get --wallet "$_wn" --chain "$_cid" >/dev/null 2>&1; then
      printf '  ok: %s already seeded\n' "$_wn"; continue
    fi
    _addr=$(clifwd wallets list 2>/dev/null | awk -v n="$_wn" '$1==n{print $2; exit}')
    [ -n "$_addr" ] || { printf '  ! %s: address not found in fwd (skipped)\n' "$_wn"; continue; }
    _j=$(docker compose --profile multichain run --rm "clif-epoch-$_n" chain nonce --address "$_addr" --json 2>/dev/null || true)
    _cnt=$(printf '%s' "$_j" | docker exec -i "$FWD_CONTAINER" python -c 'import sys,json;print(json.load(sys.stdin)["latest"])' 2>/dev/null || true)
    case "$_cnt" in
      ''|*[!0-9]*) printf '  ! %s (%s): chain nonce read failed — seed manually\n' "$_wn" "$_addr"; continue ;;
    esac
    if clifwd nonce init --wallet "$_wn" --chain "$_cid" --starting-nonce "$_cnt" >/dev/null 2>&1; then
      printf '  seeded: %s @ chain %s = %s (chain truth)\n' "$_wn" "$_cid" "$_cnt"
    else
      printf '  ! %s: nonce init failed — run: clifwd nonce init --wallet %s --chain %s --starting-nonce %s\n' "$_wn" "$_wn" "$_cid" "$_cnt"
    fi
  done
  return 0
}
_envf() {
  [ -f ".env.$1" ] || { echo "clifctl: .env.$1 not found in $CLIF_DIR — run 'sudo fwd onboard rewards …' on the fwd host (it publishes a one-shot bundle to fwd's outbox, e.g. /opt/fwd/handoff/clif-$1.json), then 'clifctl import-credentials $1 <bundle>' here" >&2; exit 2; }
}

cmd="${1:-}"; [ "$#" -gt 0 ] && shift
case "$cmd" in
  build)
    exec docker compose --profile multichain build "$@" ;;
  up)
    _net="${1:?clifctl up needs a network}"; _net_ok "$_net"; _envf "$_net"; shift
    grep -qiE '^FSP_AUTO_ENABLED=true([[:space:]]|$)' ".env.$_net" 2>/dev/null \
      || printf 'note: FSP_AUTO_ENABLED is not true in .env.%s — the daemon will IDLE (not sign), logging one disabled line + an hourly heartbeat. Set FSP_AUTO_ENABLED=true to enable signing.\n' "$_net" >&2
    set +e; docker compose --profile multichain up -d "clif-epoch-$_net" "$@"; _rc=$?; set -e
    [ "$_rc" -eq 0 ] && printf 'requested: clif-epoch-%s (epoch sign→claim daemon)\n  up -d returning 0 does not prove it stayed up — confirm: clifctl status %s | clifctl logs %s\n' "$_net" "$_net" "$_net"
    exit "$_rc" ;;
  down)
    _net="${1:?clifctl down needs a network}"; _net_ok "$_net"; shift
    exec docker compose --profile multichain rm -sf "clif-epoch-$_net" "$@" ;;
  restart)
    # Recreate (NOT `docker compose restart`) so the container RE-READS .env.<net>: a plain
    # restart keeps the env captured at creation, so an FSP_AUTO_ENABLED / FROM_EPOCH change
    # would NOT take effect. --force-recreate guarantees the current env (+ rebuilt image) is used.
    _net="${1:?clifctl restart needs a network}"; _net_ok "$_net"; _envf "$_net"; shift
    exec docker compose --profile multichain up -d --force-recreate "clif-epoch-$_net" "$@" ;;
  status)
    if [ -n "${1:-}" ] && [ "$1" != "--json" ]; then
      _net="$1"; _net_ok "$_net"; shift
      case " $* " in
        *" --json "*) exec docker exec "clif-epoch-$_net" clif epoch status --json ;;
      esac
      docker compose --profile multichain ps "clif-epoch-$_net"
      docker exec "clif-epoch-$_net" clif epoch status 2>/dev/null || true
    else
      exec docker compose --profile multichain ps
    fi ;;
  doctor)
    # Consumer self-check for the coordinator seam (ADR-0001): keyless, fwd
    # reachability, configured capabilities, compat, daemon status. One-shot (probes
    # fwd live + reads the status file), so it works with or without a running
    # daemon. Pass --json for the machine-readable scrape surface.
    _net="${1:?clifctl doctor needs a network}"; _net_ok "$_net"; _envf "$_net"; shift
    exec docker compose --profile multichain run --rm "clif-epoch-$_net" doctor "$@" ;;
  logs)
    _net="${1:?clifctl logs needs a network}"; _net_ok "$_net"; shift
    exec docker compose --profile multichain logs -f "clif-epoch-$_net" "$@" ;;
  run)
    # one-shot: override the daemon's command with the given clif args, reusing .env.<net>
    # (NETWORK + caller tokens). `docker compose run` generates its own container name, so
    # it never collides with a running daemon. e.g. clifctl run songbird claim --type fee
    _net="${1:?clifctl run needs a network}"; _net_ok "$_net"; _envf "$_net"; shift
    exec docker compose --profile multichain run --rm "clif-epoch-$_net" "$@" ;;
  import-credentials)
    # Consumer side of the fwd credential handoff (ADR-0001). Reads a one-shot
    # fwd-emitted bundle (JSON), validates it against the capabilities clif requests
    # for <net>, writes each granted caller token into this host's .env.<net>
    # IDEMPOTENTLY (the rotation channel — re-mint same id + re-import), then consumes
    # (deletes) the bundle. Keyless: the tokens are bearer caller tokens, not signing
    # keys; a token VALUE is never printed/logged. We bind-mount $CLIF_DIR into the
    # one-shot container so the env write + bundle delete land on the host.
    _net="${1:?clifctl import-credentials needs a network}"; _net_ok "$_net"; shift
    _bundle="${1:?clifctl import-credentials needs a bundle path}"; shift
    [ -f "$_bundle" ] || { echo "clifctl import-credentials: bundle not found: $_bundle" >&2; exit 1; }
    _babs=$(cd "$(dirname "$_bundle")" && pwd)/$(basename "$_bundle")
    _bdir=$(dirname "$_babs"); _bname=$(basename "$_babs")
    # Pre-create an empty .env.<net> so docker-compose's env_file directive is satisfied;
    # the importer overwrites it with the real tokens+config. (clif-epoch-<net> has env_file:.env.<net>.)
    [ -f "$CLIF_DIR/.env.$_net" ] || { ( umask 077; : > "$CLIF_DIR/.env.$_net" ); chown 1000:1000 "$CLIF_DIR/.env.$_net" 2>/dev/null || true; }
    set +e
    docker compose --profile multichain run --rm \
      -v "$CLIF_DIR:/host-clif" -v "$_bdir:/host-bundle" \
      "clif-epoch-$_net" import-credentials \
        --bundle "/host-bundle/$_bname" --env-dir /host-clif "$@"
    _rc=$?
    set -e
    # One-shot consume on the HOST: the in-container uid (1000) may be unable to
    # delete a root-owned 0600 fwd bundle, so clifctl removes it here after a
    # successful import (rc==0). A failed import leaves the bundle for retry.
    [ "$_rc" -eq 0 ] && rm -f "$_babs"
    # Auto-seed nonces from chain truth right after a successful import — only when fwd is
    # co-located (clifwd on PATH). Best-effort: never changes the import's exit code.
    if [ "$_rc" -eq 0 ] && command -v clifwd >/dev/null 2>&1; then
      printf '\n— seeding nonces from chain truth (auto) —\n'; _ns_one "$_net" || true
    fi
    exit "$_rc" ;;
  nonce-sync)
    # Seed fwd's nonce from CHAIN TRUTH for the tx-sending wallets onboard imported (claimer +
    # FSP sender — fsp-signing has no nonce). fwd is zero-egress, so this bridges: clif reads
    # the on-chain tx count, the clifwd host wrapper writes fwd's nonce. Idempotent — already
    # seeded wallets are skipped. `clifctl nonce-sync [<net>]` (default: every onboarded
    # .env.<net>). clif's install.sh runs this automatically after install.
    command -v clifwd >/dev/null 2>&1 || { echo "clifctl nonce-sync: clifwd not on PATH — is fwd installed here?" >&2; exit 2; }
    if [ -n "${1:-}" ]; then _net_ok "$1"; _ns_nets="$1"
    else _ns_nets=""; for _nf in flare songbird coston2; do [ -f ".env.$_nf" ] && _ns_nets="$_ns_nets $_nf"; done; fi
    [ -n "$_ns_nets" ] || { echo "clifctl nonce-sync: no .env.<net> in $CLIF_DIR — nothing to seed"; exit 0; }
    for _n in $_ns_nets; do _ns_one "$_n"; done
    ;;
  ""|help|-h|--help)
    echo "usage: clifctl {up|down|restart|status|logs|run|doctor} <net> [args] | import-credentials <net> <bundle> | nonce-sync [<net>] | build" >&2
    echo "       <net> = flare | songbird | coston2 ; clif is the SEPARATE reward-automation deployment" >&2
    echo "       up <net>      start the epoch sign→claim daemon (needs FSP_AUTO_ENABLED=true in .env.<net>)" >&2
    echo "       status <net> [--json]   compose + daemon health (--json = machine-readable scrape)" >&2
    echo "       doctor <net> [--json]   consumer self-check: keyless, fwd, capabilities, compat (ADR-0001)" >&2
    echo "       run <net> …   one-shot: claim --type fee | fsp uptime --epoch N | preflight --identity 0x… | chain nonce --address 0x…" >&2
    echo "       import-credentials <net> <bundle>   import + consume a one-shot fwd credential bundle into .env.<net> (ADR-0001; idempotent/rotation)" >&2
    echo "       nonce-sync    seed fwd's nonce from chain truth for imported wallets (clif reads, clifwd writes)" >&2
    [ "$cmd" = "" ] && exit 2 || exit 0 ;;
  *)
    echo "clifctl: unknown command '$cmd' (try: clifctl help)" >&2; exit 2 ;;
esac
