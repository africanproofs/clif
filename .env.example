# clif - keyless FTSO reward claimer and FSP signer.
# There is NO PRIVATE_KEY here, by design.
# The signing key lives in the fwd daemon (sealed master); clif never holds it.
# (fwd Core invariant #7 — any *PRIVATE_KEY* env var makes clif refuse to start.)

# Network: flare | songbird | coston2
NETWORK=flare

# Optional RPC overrides (defaults are the public Flare endpoints)
# FLARE_RPC=
# SONGBIRD_RPC=
# COSTON2_RPC=

# Beneficiary addresses (claimer arg, keyless — these are NOT keys)
# FEE claims use the data-provider identity address:
IDENTITY_ADDRESS=
# DIRECT claims use the signing-policy address (leave blank if the provider
# does not accrue signing-policy direct rewards):
SIGNING_POLICY_ADDRESS=

# Where claimed rewards are sent (keyless arg; authorized on-chain via
# ClaimSetupManager.setAllowedClaimRecipients by the operator):
CLAIM_RECIPIENT_ADDRESS=

# Wrap claimed rewards in wNAT (true/false). This example enables wrapping;
# the code default is false if WRAP_REWARDS is unset.
WRAP_REWARDS=true

# fwd integration — the operator provisions the wallet + caller token.
# clif consumes them; it never mints them.
FWD_ENDPOINT=http://fwd:8080
FWD_WALLET_NAME=
FWD_CALLER_TOKEN=
# Docker only: fwd's external compose network name (project-prefixed).
# FWD_NETWORK=fwd_fwd-callers

# Legacy claim-only automation (`clif auto`). The canonical daemon is
# `clif epoch run`; keep these for backward-compatible/manual operation.
# CLIF_STATE_DIR=.clif-state  # per-network deployments use .clif-state/<network>
# (per-network env files set CLIF_STATE_DIR=.clif-state/<network>)
# POLL_INTERVAL_SEC=900
# STALE_AFTER_SEC=86400
# TERMINAL_COOLDOWN_SEC=3600

# FSP signing-tool (keyless — fwd signs FSP protocol messages; clif holds zero keys).
# fwd cross-domain rule: fwd's policy loader forbids the SAME policy_path key in both
# `permissions` and `fsp_permissions` (fail-fast boot). One caller → one block.
# So Leg-1 (/v1/sign-fsp-message) and Leg-2 (/v1/sign-transaction) MUST use different
# caller tokens. Operator provisions clif-fsp-sign (fsp_permissions) and
# clif-fsp-submit (permissions for FlareSystemsManager) — clif never authors fwd policy.
# Leg-1 -> /v1/sign-fsp-message; clif-fsp-sign/fsp_permissions
FSP_SIGN_CALLER_TOKEN=
# Leg-2 -> /v1/sign-transaction; clif-fsp-submit/permissions
FSP_SUBMIT_CALLER_TOKEN=
# fwd wallet holding the signing-policy key (Leg-1)
FSP_SIGNING_WALLET_NAME=
# fwd wallet that sends the on-chain FlareSystemsManager tx (Leg-2; needs gas)
# default greenfield shape is per-network: fsp-sender-<network>
# (a shared single fsp-sender is the opt-in alternative)
FSP_SENDER_WALLET_NAME=
# Optional FSP tuning (defaults shown):
# FSP_SUBMIT_GAS=500000
# FSP_IDEMPOTENCY_RETRY=
# FSP_POLL_INTERVAL_SEC=900
# FSP_STALE_AFTER_SEC=86400
# FSP_TERMINAL_COOLDOWN_SEC=3600

# Canonical epoch daemon (`clif epoch run`). This signs and then claims each
# reward epoch, so it is HARD-OFF unless FSP_AUTO_ENABLED=true. Uptime signing
# is additionally off unless UPTIME_AUTO_ENABLED=true.
# EPOCH_REWARD_INITIAL_DELAY_SEC=3600
# EPOCH_POLL_INTERVAL_SEC=1800
# EPOCH_STALE_AFTER_SEC=86400
# EPOCH_TERMINAL_COOLDOWN_SEC=3600
# UPTIME_AUTO_ENABLED=false

# Unattended signing (`clif epoch run` and legacy `clif fsp auto`) is
# HARD-OFF by default.
# A valid signature over WRONG data is irreversible on-chain (D15 §5 risk).
# Guard stack: epoch-bind rdd assert (D15 MAJOR-1) + strict merkleRoot/n validation +
# deterministic idempotency + fwd dedup + already-signed on-chain revert.
# Only enable after reading decisions.md D15 and provisioning the two fwd callers above.
FSP_AUTO_ENABLED=false
